# Supabase
VITE_SUPABASE_URL=your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (REQUIRED for migration script to bypass RLS)
# Find this in Supabase -> Settings -> API -> service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth (Configured in Supabase Dashboard)
# Go to Authentication -> Providers -> Google

# Resend API (For custom emails, otherwise Supabase uses its own)
RESEND_API_KEY=re_123456789
